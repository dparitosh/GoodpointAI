{
  "workflows": [
    {
      "name": "Unstructured Data Pipeline - OpenSearch",
      "description": "Generic unstructured data pipeline for ingesting files (CAD, documents, logs) into OpenSearch for full-text and semantic search",
      "source": {
        "id": "filesystem_source",
        "name": "File System Source",
        "type": "filesystem",
        "connection_details": {
          "base_path": "${UNSTRUCTURED_DATA_PATH}",
          "file_patterns": [
            "*.pdf", "*.doc", "*.docx", "*.xls", "*.xlsx", "*.ppt", "*.pptx", "*.rtf", "*.odt",
            "*.stp", "*.step", "*.igs", "*.iges", "*.dxf", "*.dwg", "*.stl", "*.obj", "*.3ds",
            "*.catpart", "*.catproduct", "*.cgr", "*.sldprt", "*.sldasm", "*.prt", "*.asm",
            "*.jt", "*.x_t", "*.x_b", "*.sat", "*.sab", "*.ipt", "*.iam",
            "*.nas", "*.bdf", "*.dat", "*.inp", "*.cdb", "*.rst", "*.odb",
            "*.xml", "*.json", "*.yaml", "*.yml", "*.csv", "*.tsv",
            "*.txt", "*.log", "*.md", "*.rst",
            "*.png", "*.jpg", "*.jpeg", "*.tiff", "*.bmp", "*.gif", "*.svg",
            "*.mp4", "*.avi", "*.mov", "*.mkv",
            "*.zip", "*.tar", "*.gz", "*.7z", "*.rar",
            "*.bin", "*.dat", "*.raw"
          ]
        },
        "extraction_config": {
          "parser": "auto_detect",
          "extract_metadata": true,
          "chunk_size": 1000,
          "overlap": 200
        }
      },
      "target": {
        "id": "opensearch_target",
        "name": "OpenSearch Index",
        "type": "opensearch",
        "connection_details": {
          "url": "${OPENSEARCH_URL}",
          "index_prefix": "unstructured_"
        },
        "load_config": {
          "create_index": true,
          "bulk_size": 100,
          "enable_vectors": true
        }
      },
      "workflow_config": {
        "nodes": [],
        "edges": [],
        "ai_agents": []
      },
      "ai_agents_enabled": [],
      "created_by": "system",
      "schedule_enabled": false,
      "metadata": {
        "data_type": "unstructured",
        "pipeline_type": "search_index",
        "search_modes": ["semantic", "vector", "hybrid"]
      }
    },
    {
      "name": "Unstructured Data Pipeline - Neo4j Graph",
      "description": "Generic unstructured data pipeline for extracting entities and relationships into Neo4j knowledge graph",
      "source": {
        "id": "filesystem_source",
        "name": "File System Source",
        "type": "filesystem",
        "connection_details": {
          "base_path": "${UNSTRUCTURED_DATA_PATH}",
          "file_patterns": [
            "*.pdf", "*.doc", "*.docx", "*.xls", "*.xlsx", "*.ppt", "*.pptx",
            "*.stp", "*.step", "*.igs", "*.iges", "*.dxf", "*.dwg", "*.stl",
            "*.catpart", "*.catproduct", "*.sldprt", "*.sldasm", "*.prt", "*.asm", "*.jt",
            "*.nas", "*.bdf", "*.inp", "*.odb",
            "*.xml", "*.json", "*.yaml", "*.csv",
            "*.txt", "*.log", "*.md"
          ]
        },
        "extraction_config": {
          "parser": "entity_extractor",
          "extract_relationships": true,
          "entity_types": ["Product", "Part", "Assembly", "Document", "Person", "Organization"]
        }
      },
      "target": {
        "id": "neo4j_target",
        "name": "Neo4j Graph Database",
        "type": "neo4j",
        "connection_details": {
          "uri": "${NEO4J_URI}",
          "database": "neo4j"
        },
        "load_config": {
          "create_constraints": true,
          "merge_nodes": true,
          "batch_size": 500
        }
      },
      "workflow_config": {
        "nodes": [],
        "edges": [],
        "ai_agents": []
      },
      "ai_agents_enabled": [],
      "created_by": "system",
      "schedule_enabled": false,
      "metadata": {
        "data_type": "unstructured",
        "pipeline_type": "knowledge_graph",
        "graph_type": "entity_relationship"
      }
    },
    {
      "name": "Structured Data Pipeline - Database Migration",
      "description": "Generic structured data pipeline for migrating relational data between databases with schema mapping",
      "source": {
        "id": "database_source",
        "name": "Source Database",
        "type": "database",
        "connection_details": {
          "connection_string": "${SOURCE_DATABASE_URL}",
          "schema": "public"
        },
        "extraction_config": {
          "tables": [],
          "incremental": true,
          "watermark_column": "updated_at"
        }
      },
      "target": {
        "id": "database_target",
        "name": "Target Database",
        "type": "database",
        "connection_details": {
          "connection_string": "${TARGET_DATABASE_URL}",
          "schema": "public"
        },
        "load_config": {
          "create_tables": true,
          "truncate_before_load": false,
          "batch_size": 1000
        }
      },
      "workflow_config": {
        "nodes": [],
        "edges": [],
        "ai_agents": []
      },
      "ai_agents_enabled": [],
      "created_by": "system",
      "schedule_enabled": false,
      "metadata": {
        "data_type": "structured",
        "pipeline_type": "database_migration"
      }
    },
    {
      "name": "Structured Data Pipeline - PLM to Graph",
      "description": "Generic structured data pipeline for migrating PLM/ERP system data to Neo4j graph with BOM relationships",
      "source": {
        "id": "plm_source",
        "name": "PLM System",
        "type": "plm",
        "connection_details": {
          "endpoint": "${PLM_ENDPOINT}",
          "auth_type": "oauth2"
        },
        "extraction_config": {
          "entity_types": ["Part", "Assembly", "Document", "ChangeOrder"],
          "include_bom": true,
          "include_revisions": true
        }
      },
      "target": {
        "id": "neo4j_target",
        "name": "Neo4j Graph Database",
        "type": "neo4j",
        "connection_details": {
          "uri": "${NEO4J_URI}",
          "database": "neo4j"
        },
        "load_config": {
          "create_constraints": true,
          "merge_nodes": true,
          "preserve_history": true
        }
      },
      "workflow_config": {
        "nodes": [],
        "edges": [],
        "ai_agents": []
      },
      "ai_agents_enabled": [],
      "created_by": "system",
      "schedule_enabled": false,
      "metadata": {
        "data_type": "structured",
        "pipeline_type": "plm_graph_sync"
      }
    }
  ],
  "opensearch_indices": {
    "unstructured_documents": {
      "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "index.knn": true
      },
      "mappings": {
        "properties": {
          "doc_id": {"type": "keyword"},
          "title": {"type": "text", "fields": {"keyword": {"type": "keyword"}}},
          "content": {"type": "text"},
          "content_vector": {"type": "knn_vector", "dimension": 384, "method": {"name": "hnsw", "space_type": "cosinesimil", "engine": "nmslib"}},
          "source_file": {"type": "keyword"},
          "file_type": {"type": "keyword"},
          "created_at": {"type": "date"},
          "metadata": {"type": "object", "enabled": true},
          "entities": {"type": "keyword"},
          "chunk_index": {"type": "integer"}
        }
      }
    },
    "unstructured_entities": {
      "settings": {
        "number_of_shards": 1,
        "number_of_replicas": 0
      },
      "mappings": {
        "properties": {
          "entity_id": {"type": "keyword"},
          "name": {"type": "text", "fields": {"keyword": {"type": "keyword"}}},
          "type": {"type": "keyword"},
          "description": {"type": "text"},
          "source_documents": {"type": "keyword"},
          "related_entities": {"type": "keyword"},
          "properties": {"type": "object", "enabled": true},
          "created_at": {"type": "date"}
        }
      }
    }
  },
  "neo4j_schema": {
    "constraints": [
      "CREATE CONSTRAINT doc_id IF NOT EXISTS FOR (d:Document) REQUIRE d.doc_id IS UNIQUE",
      "CREATE CONSTRAINT entity_id IF NOT EXISTS FOR (e:Entity) REQUIRE e.entity_id IS UNIQUE",
      "CREATE CONSTRAINT part_id IF NOT EXISTS FOR (p:Part) REQUIRE p.part_id IS UNIQUE",
      "CREATE CONSTRAINT assembly_id IF NOT EXISTS FOR (a:Assembly) REQUIRE a.assembly_id IS UNIQUE"
    ],
    "indexes": [
      "CREATE INDEX doc_title IF NOT EXISTS FOR (d:Document) ON (d.title)",
      "CREATE INDEX entity_name IF NOT EXISTS FOR (e:Entity) ON (e.name)",
      "CREATE INDEX part_name IF NOT EXISTS FOR (p:Part) ON (p.name)"
    ]
  },
  "search_config": {
    "semantic_search": {
      "enabled": true,
      "model": "sentence-transformers/all-MiniLM-L6-v2",
      "dimension": 384,
      "similarity_threshold": 0.7
    },
    "vector_search": {
      "enabled": true,
      "k": 10,
      "ef_search": 100
    },
    "hybrid_search": {
      "enabled": true,
      "text_weight": 0.5,
      "vector_weight": 0.5
    }
  }
}
