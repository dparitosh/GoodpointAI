OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_TIMEOUT_S=30
OPENSEARCH_INDEX_PREFIX=graphtrace

# ============================================================================
# PLM SYSTEMS
# ============================================================================

# Teamcenter
TEAMCENTER_URL=https://your-teamcenter-server
