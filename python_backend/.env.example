TEAMCENTER_PASSWORD=your_tc_password
TEAMCENTER_SOAP_URL=https://your-teamcenter-server/tc/services
TEAMCENTER_REST_URL=https://your-teamcenter-server/tc/rest

# Windchill
WINDCHILL_URL=https://your-windchill-server
WINDCHILL_USERNAME=your_wc_username
WINDCHILL_PASSWORD=your_wc_password
