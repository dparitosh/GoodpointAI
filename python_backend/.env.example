ARAS_PASSWORD=your_aras_password

# ============================================================================
# FILE SYSTEM CONFIGURATION
# ============================================================================

# Data Directories
DATA_ROOT_PATH=./data
UPLOAD_DIR=./data/uploads
TEMP_DIR=./data/temp
EXPORT_DIR=./data/exports
LOG_DIR=./logs

# File Input Paths
XML_INPUT_PATH=./data/xml/input
JSON_INPUT_PATH=./data/json/input
CSV_INPUT_PATH=./data/csv/input

# Folder Monitoring
# CRITICAL: WATCH_FOLDERS must be in JSON array format to avoid JSONDecodeError
# This is a required format due to Pydantic settings validation
# 
# Supported formats:
#   JSON array (RECOMMENDED):       WATCH_FOLDERS='["./data/watch","./uploads"]'
#   Semicolon-separated (Windows): WATCH_FOLDERS="./data/watch;./uploads"
#   Comma-separated (Unix):        WATCH_FOLDERS="./data/watch,./uploads"
#   Single path:                   WATCH_FOLDERS="./data/watch"
#   Unset/Empty:                   Defaults to ["./data/watch"]
#
# DO NOT use these formats (they cause errors):
#   ❌ WATCH_FOLDERS=./data/watch           <- Will fail with JSONDecodeError
#   ❌ WATCH_FOLDERS=["./data/watch"]       <- Extra quotes cause parsing error
#
# If you see: pydantic_settings.exceptions.SettingsError: error parsing value 
# for field "watch_folders", check that WATCH_FOLDERS is set to one of the 
# supported formats above, or unset it to use the default.
WATCH_FOLDERS=["./data/watch"]

# File Size Limits (in MB)
MAX_UPLOAD_SIZE_MB=100
MAX_BATCH_SIZE_MB=500

# ============================================================================
# API GATEWAY CONFIGURATION
# ============================================================================

# Generic API Gateway
API_GATEWAY_URL=https://your-api-gateway.com
API_GATEWAY_KEY=your_api_key
API_GATEWAY_SECRET=your_api_secret

# Kong API Gateway
KONG_ADMIN_URL=http://localhost:8001
KONG_GATEWAY_URL=http://localhost:8000
KONG_API_KEY=your_kong_api_key

# Apigee
APIGEE_ORG=your_organization
APIGEE_ENV=prod
APIGEE_USERNAME=your_apigee_username
APIGEE_PASSWORD=your_apigee_password

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment
ENVIRONMENT=development
DEBUG=true

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Security
SECRET_KEY=your_secret_key_for_jwt
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
