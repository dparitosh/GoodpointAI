# =============================================================================
# GraphTrace Frontend — Environment Configuration Template
# =============================================================================
# Copy this file to .env.development (for local dev) or .env.production.
# Vite only exposes variables prefixed VITE_ to the browser bundle.
# Never put secrets or API keys here.
# =============================================================================

# --- API Base URL ------------------------------------------------------------
# Optional: override the API base URL used by all apiClient calls.
# For single-machine dev with the Vite proxy:  leave empty (proxy handles /api/*)
# For VM / Docker deployment:                  set to the backend origin
# Example: VITE_API_BASE_URL=http://10.0.0.20:8011
VITE_API_BASE_URL=

# --- Vite Dev-Server Proxy Target --------------------------------------------
# Controls where the Vite dev server proxies /api/* and /health requests.
# Default:  http://127.0.0.1:8011
# VM/Docker: http://<backend-host>:<port>
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8011

# --- Backend Port (display only, not used for routing) -----------------------
# Shown in diagnostics / help text. Does NOT affect actual connectivity.
VITE_BACKEND_PORT=8011

# --- Feature Flags -----------------------------------------------------------
# Enable verbose API call logging in the browser console (dev only).
# VITE_DEBUG_API=true

# --- Auth (future use) -------------------------------------------------------
# VITE_AUTH_ENABLED=false
