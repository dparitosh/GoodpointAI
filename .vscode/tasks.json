{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Frontend Development Server",
			"type": "shell",
			"command": "npm run dev -- --host 127.0.0.1 --port 5173",
			"options": {
				"cwd": "${workspaceFolder}/e2etraceapp"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Start Backend Server",
			"type": "shell",
			"command": "${command:python.interpreterPath}",
			"args": [
				"-m",
				"uvicorn",
				"--app-dir",
				"${workspaceFolder}/python_backend",
				"main:app",
				"--host",
				"0.0.0.0",
				"--port",
				"8011",
				"--reload"
			],
			"options": {
				"cwd": "${workspaceFolder}/python_backend",
				"env": {
					"GRAPH_TRACE_LOAD_DOTENV": "true"
				}
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Backend Server (No Reload)",
			"type": "shell",
			"command": "${command:python.interpreterPath}",
			"args": [
				"-m",
				"uvicorn",
				"--app-dir",
				"${workspaceFolder}/python_backend",
				"main:app",
				"--host",
				"0.0.0.0",
				"--port",
				"8011"
			],
			"options": {
				"cwd": "${workspaceFolder}/python_backend",
				"env": {
					"GRAPH_TRACE_LOAD_DOTENV": "true"
				}
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Backend Server (OpenSearch)",
			"type": "shell",
			"command": "${command:python.interpreterPath}",
			"args": [
				"-m",
				"uvicorn",
				"main:app",
				"--host",
				"0.0.0.0",
				"--port",
				"8008"
			],
			"options": {
				"cwd": "${workspaceFolder}/python_backend",
				"env": {
					"GRAPH_TRACE_LOAD_DOTENV": "true",
					"OPENSEARCH_URL": "http://localhost:9200",
					"OPENSEARCH_TIMEOUT_S": "30"
				}
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Backend Server (Auth Required)",
			"type": "shell",
			"command": "${command:python.interpreterPath}",
			"args": [
				"-m",
				"uvicorn",
				"main:app",
				"--host",
				"0.0.0.0",
				"--port",
				"8003",
				"--reload"
			],
			"options": {
				"cwd": "${workspaceFolder}/python_backend",
				"env": {
					"GRAPH_TRACE_LOAD_DOTENV": "true",
					"GRAPH_TRACE_AUTH_REQUIRED": "true",
					"GRAPH_TRACE_JWT_SECRET": "${env:GRAPH_TRACE_JWT_SECRET}",
					"GRAPH_TRACE_ADMIN_USERNAME": "${env:GRAPH_TRACE_ADMIN_USERNAME}",
					"GRAPH_TRACE_ADMIN_PASSWORD": "${env:GRAPH_TRACE_ADMIN_PASSWORD}"
				}
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Full Stack (Frontend + Backend)",
			"dependsOn": [
				"Start Backend Server",
				"Start Frontend Development Server"
			],
			"dependsOrder": "parallel",
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Full Stack (graphtrace.ps1)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\graphtrace.ps1",
				"-Start"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Diagnostics Check",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\graphtrace.ps1",
				"-Check"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Frontend: Lint",
			"type": "shell",
			"command": "npm run lint",
			"options": {
				"cwd": "${workspaceFolder}/e2etraceapp"
			},
			"problemMatcher": []
		},
		{
			"label": "Frontend: Test (Vitest run)",
			"type": "shell",
			"command": "npm test -- --run",
			"options": {
				"cwd": "${workspaceFolder}/e2etraceapp"
			},
			"problemMatcher": []
		},
		{
			"label": "Backend: Test (Pytest)",
			"type": "shell",
			"command": "${command:python.interpreterPath}",
			"args": [
				"-m",
				"pytest"
			],
			"options": {
				"cwd": "${workspaceFolder}/python_backend",
				"env": {
					"GRAPH_TRACE_LOAD_DOTENV": "true"
				}
			},
			"problemMatcher": []
		},
		{
			"label": "MCP: Start Inspector",
			"type": "shell",
			"command": "npx @modelcontextprotocol/inspector",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Git: Push current branch",
			"type": "shell",
			"command": "git push origin HEAD",
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}