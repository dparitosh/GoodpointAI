# MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Service Identity
# =============================================================================
MCP_SERVER_ID=mcp-server-01
MCP_SERVER_PORT=8012
MCP_SERVER_HOST=0.0.0.0

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection for task history and agent registry
# For VM deployment: Replace 'localhost' with database server IP
# Example: postgresql://postgres:yourpassword@10.0.0.10:5433/graphtrace
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5433/graphtrace

# Redis for state management and caching
# For VM deployment: Replace 'localhost' with Redis server IP
# Example: redis://10.0.0.10:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# =============================================================================
# Message Queue Configuration
# =============================================================================
# Azure Service Bus (production)
# AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...
# MCP_TASK_QUEUE_NAME=mcp-tasks
# MCP_RESULT_QUEUE_NAME=mcp-results

# OR local queue alternative (development)
USE_LOCAL_QUEUE=true
LOCAL_QUEUE_BACKEND=memory  # memory, redis, or azurite

# =============================================================================
# Agent Configuration
# =============================================================================
# Agent registry backend: postgres, redis, or memory
AGENT_REGISTRY_BACKEND=postgres

# Agent health monitoring
AGENT_HEARTBEAT_INTERVAL_SECONDS=30
AGENT_TIMEOUT_SECONDS=120
AGENT_MAX_RETRIES=3

# Agent discovery endpoints (if agents register themselves)
# Leave empty to use database-based registry
# AGENT_DISCOVERY_ENDPOINTS=http://agent1:8080,http://agent2:8080

# =============================================================================
# Performance Tuning
# =============================================================================
MAX_CONCURRENT_TASKS=50
TASK_TIMEOUT_DEFAULT_SECONDS=30
QUEUE_POLL_INTERVAL_SECONDS=1
TASK_RETRY_MAX_ATTEMPTS=3
TASK_RETRY_BACKOFF_SECONDS=5

# Connection pools
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
REDIS_POOL_SIZE=50

# =============================================================================
# Security & Authentication
# =============================================================================
# JWT for service-to-service auth
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600

# API Key authentication (optional, for emergency access)
# MCP_API_KEY=your-secure-api-key-here

# Azure Managed Identity (production)
# AZURE_CLIENT_ID=your-managed-identity-client-id
# AZURE_TENANT_ID=your-tenant-id

# Azure Key Vault for secrets (production)
# KEY_VAULT_NAME=kv-graphtrace-dev
# JWT_SECRET_KEY_VAULT_NAME=mcp-jwt-secret

# =============================================================================
# Observability
# =============================================================================
# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # or text
LOG_FILE=/var/log/mcp-server/app.log  # leave empty for stdout only

# Metrics
ENABLE_METRICS=true
METRICS_PORT=8012  # same as main port, /metrics endpoint
METRICS_PREFIX=mcp_server

# Tracing (OpenTelemetry)
ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=mcp-server
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp

# Azure Application Insights (production)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_CHAT_COORDINATION=true
ENABLE_COLLABORATIVE_TASKS=true
ENABLE_TASK_PRIORITIZATION=true
ENABLE_AGENT_LOAD_BALANCING=true

# =============================================================================
# Development / Testing
# =============================================================================
# Set to true for local development with auto-reload
DEVELOPMENT_MODE=true

# Mock agent responses (for testing without real agents)
MOCK_AGENTS=false

# Disable authentication for local dev
DISABLE_AUTH=true

# =============================================================================
# External Service Integrations
# =============================================================================
# Main Backend API (for callbacks, if needed)
BACKEND_API_URL=http://localhost:8011

# Neo4j (if MCP server needs direct access)
# NEO4J_URI=neo4j://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=password123

# LLM APIs (if MCP server coordinates LLM calls)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=...
